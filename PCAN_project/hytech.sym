FormatVersion=6.0 // Do not edit this line!
UniqueVariables=True
Title="SYM Database"

{ENUMS}
Enum=dial_stateE(0="MODE_0", 1="MODE_1", 2="MODE_2", 3="MODE_3", 4="MODE_4", 5="MODE_5")
Enum=vn_gps_statusE(0="NO_FIX", 1="TIME_ONLY", 2="FIX_2D", 3="FIX_3D")
Enum=torque_controller_mux_statusE(0="NO_ERROR", 1="ERROR_SPEED_DIFF_TOO_HIGH", 2="ERROR_TORQUE_DIFF_TOO_HIGH",
  3="ERROR_CONTROLLER_INDEX_OUT_OF_BOUNDS", 4="ERROR_CONTROLLER_NULL_POINTER")
Enum=Broadcast_rateE(0="hz_1", 1="hz_5", 2="hz_10", 3="hz_50", 4="hz_100", 5="hz_250", 6="hz_500")
Enum=CAN_Termination_Setting_Bus_1E(0="CAN_BUS_UNTERMINATED_CAN1_setting", 1="CAN_BUS_TERMINATED_CAN1_setting")
Enum=CAN_Termination_Setting_Bus_2E(0="CAN_BUS_UNTERMINATED_CAN2_setting", 1="CAN_BUS_TERMINATED_CAN2_setting")
Enum=Attitude_FilteringE(0="NO_FILTERING_ATT", 1="LIGHT_FILTERING_ATT", 2="MEDIUM_FILTERING_ATT",
  3="HEAVY_FILTERING_ATT")
Enum=IMU_FilteringE(0="NO_FILTERING_IMU", 1="LIGHT_FILTERING_IMU", 2="MEDIUM_FILTERING_IMU", 3="HEAVY_FILTERING_IMU")
Enum=Velocity_FilteringE(0="NO_FILTERING_VEL", 1="LIGHT_FILTERING_VEL", 2="MEDIUM_FILTERING_VEL",
  3="HEAVY_FILTERING_VEL")
Enum=sensor_0_ValidityE(0="Sensor_Valid_sense_0", 1="Response_Timeout_sense_0", 2="Bad_Optical_Signal_sense_0",
  3="Speed_Too_High_sense_0")
Enum=sensor_1_ValidityE(0="Sensor_Valid_sense_1", 1="Response_Timeout_sense_1", 2="Bad_Optical_Signal_sense_1",
  3="Speed_Too_High_sense_1")
Enum=sensor_2_ValidityE(0="Sensor_Valid_sense_2", 1="Response_Timeout_sense_2", 2="Bad_Optical_Signal_sense_2",
  3="Speed_Too_High_sense_2")
Enum=sensor_3_ValidityE(0="Sensor_Valid_sense_3", 1="Response_Timeout_sense_3", 2="Bad_Optical_Signal_sense_3",
  3="Speed_Too_High_sense_3")
Enum=SpeedBeam_HealthE(0="SENSOR_HEALTHY", 1="NON_MEASUREMENT_MODE", 2="DATA_OPTICAL_QUALITY_POOR",
  3="TEMPERATURE_TOO_HIGH", 4="SAVING_CALIBRATION", 5="SENSOR_COMMUNICATION_ERROR", 6="SPEED_TOO_HIGH")
Enum=CAN_Termination_State_Bus_1E(0="CAN_BUS_UNTERMINATED_CAN1_STATUS", 1="CAN_BUS_TERMINATED_CAN1_STATUS")
Enum=CAN_Termination_State_Bus_2E(0="CAN_BUS_UNTERMINATED_CAN2_STATUS", 1="CAN_BUS_TERMINATED_CAN2_STATUS")
Enum=vehicle_stateE(0="TRACTIVE_SYSTEM_NOT_ACTIVE", 1="TRACTIVE_SYSTEM_ACTIVE", 2="WANTING_READY_TO_DRIVE",
  3="READY_TO_DRIVE", 4="WANTING_RECALIBRATE_PEDALS", 5="RECALIBRATING_PEDALS", 6="WANTING_RECALIBRATE_STEERING",
  7="RECALIBRATING_STEERING")
Enum=drivetrain_stateE(0="NOT_CONNECTED", 1="NOT_ENABLED_NO_HV_PRESENT", 2="NOT_ENABLED_HV_PRESENT",
  3="INVERTERS_READY", 4="INVERTERS_HV_ENABLED", 5="ENABLED_DRIVE_MODE", 6="ERROR", 7="CLEARING_ERRORS")

